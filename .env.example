# ─────────────────────────────────────────────
# AdScale Labs — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Core ──────────────────────────────────────
# Path to the SQLite database file
DB_PATH=./data/adscale.db

# Express server port
PORT=3001

# Secret token that protects the /run-agent/:name endpoint.
# n8n workflows pass this in the Authorization header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_TOKEN=your_32_char_hex_token_here

# ── Anthropic (Claude) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Nodemailer via SMTP) ────────────────
# Used by Larry SDR to send welcome emails and follow-ups.
# Works with Gmail, Mailgun, SendGrid SMTP, Postmark, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM="AdScale Labs <your@email.com>"

# Optional: SendGrid API key as a fallback to SMTP
# If set, Larry will prefer SendGrid over Nodemailer
SENDGRID_API_KEY=

# ── ManyChat (Instagram DMs) ──────────────────
# Used by Larry SDR to send IG direct messages.
# Get from ManyChat → Settings → API
MANYCHAT_API_KEY=

# ── Calendly (Auto-booking) ───────────────────
# Used by Larry SDR to book qualified leads.
# Get from Calendly → Integrations → API & Webhooks
CALENDLY_API_KEY=
# The specific event type UUID to book into (copy from Calendly URL)
CALENDLY_EVENT_TYPE_UUID=

# ── Stripe (Payment webhooks for Cleo) ────────
# Get from Stripe Dashboard → Developers → API Keys → Secret key (for Stripe SDK)
STRIPE_SECRET_KEY=sk_live_...
# Get from Stripe Dashboard → Developers → Webhooks → signing secret (for webhook verification)
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Tally (Form webhooks for Larry + Cleo) ────
# Set this to any random secret, then configure in Tally webhook settings
TALLY_WEBHOOK_SECRET=your_tally_secret
# The full URL of your Tally onboarding form (the 28-question form for new clients)
TALLY_ONBOARDING_FORM_URL=https://tally.so/r/your_onboarding_form_id

# ── RapidAPI (Instagram scraping for Scout + Cleo) ── FREE TIER
# Free tier: 500 requests/month (enough for daily Scout + client onboarding)
# 1. Sign up at rapidapi.com
# 2. Search "Instagram Scraper API2" → Subscribe to the FREE plan
# 3. Copy your key from rapidapi.com → Apps → default-application → Authorization
RAPIDAPI_KEY=your_rapidapi_key_here

# ── Instagram Basic Display API (for Analyst) ──
# Get from developers.facebook.com → Your App → Instagram Basic Display
IG_ACCESS_TOKEN=
IG_USER_ID=

# ── CORS (dashboard origin) ───────────────────
# Origin allowed to fetch from the Express server (production — set to your dashboard domain)
DASHBOARD_ORIGIN=http://localhost:3000

# ── n8n Integration ───────────────────────────
# Reference only — not read by server code. For your records.
N8N_WEBHOOK_BASE_URL=https://n8n.yourhosting.com
# IMPORTANT: In your n8n instance settings (not this .env file), set:
#   ADSCALE_SERVER_URL = https://your-public-server-url.com
# The n8n workflow JSONs reference $env.ADSCALE_SERVER_URL and $env.INTERNAL_TOKEN

# ── Dashboard (Next.js) ───────────────────────
# The API base URL the dashboard fetches from (the Express server)
NEXT_PUBLIC_API_BASE=http://localhost:3001

# Path to the SQLite database, relative to the dashboard/ directory
# ".." goes up one level to the monorepo root, then into data/
DASHBOARD_DB_PATH=../data/adscale.db
