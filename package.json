{
  "name": "adscale-labs",
  "version": "1.0.0",
  "description": "AI-powered marketing and sales automation system for AdScale Labs",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:init": "node -e \"require('./lib/database')\"",
    "seed": "node scripts/seed.js",
    "seed:force": "node scripts/seed.js --force",
    "agent:scout": "node agents/scout.js",
    "agent:scripter": "node agents/scripter.js",
    "agent:larry": "node agents/larry-sdr.js",
    "agent:analyst": "node agents/analyst.js",
    "agent:cleo": "node agents/cleo-onboarding.js",
    "agent:optimizer": "node agents/optimizer.js",
    "agent:scout:dry": "node agents/scout.js --dry-run",
    "agent:scripter:dry": "node agents/scripter.js --dry-run",
    "agent:larry:dry": "node agents/larry-sdr.js --dry-run",
    "agent:analyst:dry": "node agents/analyst.js --dry-run",
    "agent:cleo:dry": "node agents/cleo-onboarding.js --dry-run",
    "agent:optimizer:dry": "node agents/optimizer.js --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "puppeteer": "^24.40.0",
    "stripe": "^15.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
